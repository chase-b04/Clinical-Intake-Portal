# Copy this file to .env.local and fill in your ServiceNow PDI details.
# .env.local is gitignored and should never be committed.

# Full base URL for your scoped app's REST API namespace, e.g.
# https://dev12345.service-now.com/api/x_your_scope/task4
SERVICENOW_API_BASE_URL=

# Dedicated integration user credentials (see planning.md, Step 1).
SN_USER=
SN_PASSWORD=
